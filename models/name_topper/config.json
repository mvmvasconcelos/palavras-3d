{
    "id": "name_topper",
    "name": "Letreiro Personalizado",
    "description": "Crie um letreiro 3D de alta qualidade com texto em duas linhas, cores customizáveis e furação para chaveiro ou topper de bolo.",
    "thumbnail": "/static/img/name_topper_thumb.png",
    "features": [
        "preview2d"
    ],
    "parameters": [
        {
            "id": "text_line_1",
            "label": "Linha 1",
            "type": "text",
            "default": "Vinicius"
        },
        {
            "id": "text_size_1",
            "label": "Tamanho Linha 1 (mm)",
            "type": "number",
            "min": 5,
            "max": 50,
            "step": 1,
            "default": 12
        },
        {
            "id": "font_name",
            "label": "Fonte",
            "type": "font_select",
            "default": "Comic Neue:style=Bold"
        }
    ],
    "categories": [
        {
            "name": "Linha 2 (Opcional)",
            "parameters": [
                {
                    "id": "text_line_2",
                    "label": "Texto Linha 2",
                    "type": "text",
                    "placeholder": "Ex: Aniversário",
                    "default": ""
                },
                {
                    "id": "text_size_2",
                    "label": "Tamanho Linha 2 (mm)",
                    "type": "number",
                    "min": 5,
                    "max": 50,
                    "step": 1,
                    "default": 10
                }
            ]
        },
        {
            "name": "Cores",
            "parameters": [
                {
                    "id": "base_color",
                    "label": "Cor da Base",
                    "type": "color",
                    "default": "#1B40D1"
                },
                {
                    "id": "letters_color",
                    "label": "Cor das Letras",
                    "type": "color",
                    "default": "#FFFFFF"
                }
            ]
        },
        {
            "name": "Ajustes Finos",
            "parameters": [
                {
                    "id": "letter_height",
                    "label": "Altura da letra (mm)",
                    "type": "number",
                    "min": 0.2,
                    "max": 10.0,
                    "step": 0.1,
                    "default": 1.4
                },
                {
                    "id": "base_height",
                    "label": "Altura da base (mm)",
                    "type": "number",
                    "min": 1,
                    "max": 50,
                    "step": 1,
                    "default": 12
                },
                {
                    "id": "outline_margin",
                    "label": "Margem do contorno (mm)",
                    "type": "number",
                    "min": 0,
                    "max": 10,
                    "step": 0.1,
                    "default": 2.3
                },
                {
                    "id": "spacing",
                    "label": "Espaçamento das Letras",
                    "type": "range",
                    "min": 0.5,
                    "max": 2.0,
                    "step": 0.05,
                    "default": 1.0
                },
                {
                    "id": "line_spacing",
                    "label": "Distância entre linhas",
                    "type": "range",
                    "min": 0.1,
                    "max": 2.0,
                    "step": 0.05,
                    "default": 1.0
                }
            ]
        },
        {
            "name": "Furação",
            "parameters": [
                {
                    "id": "hole_orientation",
                    "label": "Orientação do Furo",
                    "type": "select",
                    "options": [
                        {
                            "value": "TOPBOTTOM",
                            "label": "Vertical (Chaveiro/Topper)"
                        },
                        {
                            "value": "FRONTBACK",
                            "label": "Horizontal (Passante)"
                        },
                        {
                            "value": "NONE",
                            "label": "Sem Furo"
                        }
                    ],
                    "default": "TOPBOTTOM"
                },
                {
                    "id": "hole_type",
                    "label": "Formato do Furo",
                    "type": "select",
                    "options": [
                        {
                            "value": "CIRCLE",
                            "label": "Círculo"
                        },
                        {
                            "value": "HEXAGON",
                            "label": "Hexágono"
                        }
                    ],
                    "default": "CIRCLE"
                },
                {
                    "id": "hole_diameter",
                    "label": "Diâmetro do Furo (mm)",
                    "type": "number",
                    "min": 1,
                    "max": 20,
                    "step": 0.1,
                    "default": 7.8
                }
            ]
        }
    ]
}